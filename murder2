-- 5. CHẠY PHẦN TRĂM MƯỢT MÀ (DYNAMIC STEPS)
-- ==========================================
local currentPercent = 0

local function runLoadingStep(targetPercent, statusText, duration)
    StatusLabel.Text = statusText
    local steps = 25
    local increment = (targetPercent - currentPercent) / steps
    local stepDelay = duration / steps
    
    for i = 1, steps do
        currentPercent = currentPercent + increment
        local displayPercent = math.clamp(math.round(currentPercent), 0, 100)
        
        BarFill.Size = UDim2.new(displayPercent / 100, 0, 1, 0)
        PercentLabel.Text = tostring(displayPercent) .. "%"
        
        -- Chuyển dần màu chữ theo tiến trình
        PercentLabel.TextColor3 = Color3.fromRGB(58, 134, 255):Lerp(Color3.fromRGB(100, 255, 100), displayPercent / 100)
        
        task.wait(stepDelay)
    end
end

